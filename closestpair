#include<iostream>
#include<cmath>
#include<cfloat>
using namespace std;
int main()
{
   int n;
   cout<<"Enter no of points:";
   cin>>n;
   int x[100],y[100];
   for(int i=0;i<n;i++)
   {
      cin>>x[i]>>y[i];
   }
   float d;
   d=FLT_MAX;
   int p1=0,p2=0;
   for(int i=1;i<=n-1;i++)
   {
      for(int j=i+1;j<=n;j++)
      {
         double dist=sqrt(pow((x[i]-x[j]),2)+pow((y[i]-y[j]),2));
         cout<<"distance between pair:("<<x[i]<<","<<y[i]<<")("<<x[j]<<","<<y[j]<<")""distance ="<<dist<<endl;
         if(dist<d)
         {
            d=dist;
            p1=i;
            p2=j;
         }
      }
   }
   cout<<"closest pair:("<<x[p1]<<","<<y[p1]<<")("<<x[p2]<<","<<y[p2]<<")"<<endl;
   cout<<"minimum distance"<<d<<endl;
   return 0;
}
