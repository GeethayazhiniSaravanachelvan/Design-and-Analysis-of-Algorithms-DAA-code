#include<iostream>
using namespace std;
int main()
{
   int n;
   cout<<"Enter no of vertices:";
   cin>>n;
   int D[n][n];
   cout<<"Enter path (9999 for no path):";
   for(int i=0;i<n;i++)
   {
      for(int j=0;j<n;j++)
      {
         cin>>D[i][j];
      }
   }
   for(int k=0;k<n;k++)
   {
      for(int i=0;i<n;i++)
      {
         for(int j=0;j<n;j++)
         {
            if(D[i][k] + D[k][j] < D[i][j])
            {
               D[i][j] = D[i][k] + D[k][j];
            }
         }
      }
   }
   cout<<"\n Shortest distance Matrix:\n";
   for(int i=0;i<n;i++)
   {
      for(int j=0;j<n;j++)
      {
         cout<<D[i][j]<<" ";
      }
      cout<<endl;
   }
   return 0;
}
