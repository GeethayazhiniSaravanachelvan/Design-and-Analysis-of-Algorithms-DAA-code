#include<iostream>
#include<string>
using namespace std;
int main()
{
   string T,P;
   int n=0,m=0;
   cout<<"Enter text:";
   getline(cin,T);
   cout<<"Enter pattern:";
   getline(cin,P);
   while(T[n]!='\0')
      n++;
   while(P[m]!='\0')
      m++;
   for(int i=0;i<=n-m;i++)
   {
      int j=0;
      while(j<m&&P[j]==T[i+j])
         j++;
      if(j==m)
      {
         cout<<"Pattern found at index "<<i;
         for(int row=0;row<i+1;row++)
         {
            for(int space=0;space<row;space++)
            {
               cout<<" "<<endl;
            }
          cout<<P<<endl;
         }
      }
   }
   cout<<"Pattern not found";
   return 0;
}
