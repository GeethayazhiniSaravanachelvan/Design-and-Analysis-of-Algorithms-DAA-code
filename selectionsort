#include<iostream>
using namespace std;
int main()
{
   int n,temp,min;
   cout<<"Enter no of elements";
   cin>>n;
   int a[n];
   cout<<"Enter elements";
   for(int i=0;i<n;i++)
   {
      cin>>a[i];
   }
   for(int i=0;i<n-1;i++)
   {
      min=i;
      for(int j=i+1;j<n;j++)
      {
         if(a[j]<a[min])
         {
            min=j;
         }
      }
      if(min!=i)
      {
         temp=a[i];
         a[i]=a[min];
         a[min]=temp;
      }
   }
   cout<<"AFTER SORTING";
   for(int i=0;i<n;i++)
   {
      cout<<a[i];
   }
}
